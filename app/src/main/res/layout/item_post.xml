<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout item post di RecyclerView.
    Mendukung tampilan repost:
      - tvRepostLabel  : label "🔁 Nama merepost" (GONE jika post asli)
      - btnRepost      : tombol repost dengan warna aktif saat is_reposted = true
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="0dp"
    android:layout_marginVertical="4dp"
    app:cardCornerRadius="0dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="8dp">

        <!-- ── Label Repost ("🔁 Nama merepost") ───────────────────────────── -->
        <TextView
            android:id="@+id/tvRepostLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="56dp"
            android:paddingTop="8dp"
            android:paddingBottom="2dp"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:visibility="gone"
            tools:text="Budi merepost"
            tools:visibility="visible" />

        <!-- ── Baris atas: avatar + nama + tombol hapus ─────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/ivAvatar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_default_avatar"
                android:scaleType="centerCrop"
                android:contentDescription="@string/avatar" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="10dp">

                <TextView
                    android:id="@+id/tvDisplayName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"
                    tools:text="Budi Santoso" />

                <TextView
                    android:id="@+id/tvUsername"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    tools:text="@budisantoso" />

                <TextView
                    android:id="@+id/tvTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    tools:text="2j" />
            </LinearLayout>

            <!-- Tombol hapus (hanya tampil untuk pemilik post) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/ivDelete"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:visibility="gone"
                app:icon="@drawable/ic_delete"
                app:iconTint="@color/error"
                app:iconSize="18dp" />
        </LinearLayout>

        <!-- ── Konten teks ─────────────────────────────────────────────────── -->
        <TextView
            android:id="@+id/tvContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="62dp"
            android:paddingBottom="8dp"
            android:textSize="14sp"
            android:textColor="@color/text_primary"
            android:lineSpacingMultiplier="1.3"
            tools:text="Ini adalah konten post contoh yang panjang untuk menguji tampilan." />

        <!-- ── Gambar (opsional) ───────────────────────────────────────────── -->
        <FrameLayout
            android:id="@+id/imageContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="62dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="8dp"
            android:visibility="gone">

            <ImageView
                android:id="@+id/ivPostImage"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_rounded_8"
                android:contentDescription="@string/post_image" />

            <!-- Badge "+N" jika ada lebih dari 1 gambar -->
            <TextView
                android:id="@+id/tvMoreImages"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|end"
                android:layout_margin="8dp"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:backgroundTint="#99000000"
                android:background="@drawable/bg_rounded_8"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:visibility="gone"
                tools:text="+2" />
        </FrameLayout>

        <!-- ── Divider tipis ───────────────────────────────────────────────── -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:layout_marginHorizontal="12dp"
            android:background="@color/divider" />

        <!-- ── Tombol aksi: Like · Comment · Repost ───────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="54dp"
            android:paddingEnd="4dp"
            android:paddingTop="4dp"
            android:gravity="center_vertical">

            <!-- Like -->
            <ImageView
                android:id="@+id/ivLike"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_heart_outline"
                android:padding="4dp"
                android:contentDescription="Like" />

            <TextView
                android:id="@+id/tvLikeCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginEnd="12dp"
                tools:text="42" />

            <!-- Comment -->
            <ImageView
                android:id="@+id/ivComment"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_comment"
                android:padding="4dp"
                android:contentDescription="Comment" />

            <TextView
                android:id="@+id/tvCommentCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginEnd="12dp"
                tools:text="5" />

            <!-- Repost -->
            <ImageView
                android:id="@+id/ivRepost"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_repost_outline"
                android:padding="4dp"
                android:contentDescription="Repost" />

            <TextView
                android:id="@+id/tvRepostCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="10dp"
                tools:text="3" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>