<?xml version="1.0" encoding="utf-8"?>
<!--
    res/color/btn_repost_tint.xml
    Warna ikon tombol repost:
      - selected (is_reposted = true) → warna hijau "repost_active"
      - default                       → warna ikon biasa
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true"  android:color="@color/repost_active" />
    <item                                android:color="?attr/colorOnSurfaceVariant" />
</selector>