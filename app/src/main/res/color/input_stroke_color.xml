<?xml version="1.0" encoding="utf-8"?>
<!--
    res/color/input_stroke_color.xml

    Warna outline/border TextInputLayout yang adaptive:
    - Light mode : abu-abu medium agar terlihat di background putih
    - Dark mode  : abu-abu terang agar terlihat di background gelap
    - Saat focused (state_focused) : pakai warna primary agar user tahu field aktif
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Focused – pakai primary supaya konsisten di kedua mode -->
    <item android:state_focused="true"
        android:color="@color/primary"/>

    <!-- Unfocused Light mode -->
    <item android:color="#99000000"
        android:state_enabled="true"/>

</selector>